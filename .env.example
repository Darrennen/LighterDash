# Copy to .env to override defaults

# Upstream Lighter API base URL
LIGHTER_API=https://mainnet.zklighter.elliot.ai/api/v1

# Collector poll interval in seconds
COLLECT_INTERVAL=5

# How many top-volume markets to pull trades from per cycle
TOP_N_MARKETS=15

# Trades per market per cycle
RECENT_TRADES_LIMIT=50

# Default whale threshold (USD) for persistence
WHALE_DEFAULT_USD=50000

# Retention window for SQLite history (days)
HISTORY_RETENTION_DAYS=30

# SQLite path (relative to repo root)
DB_PATH=data/cockpit.db

# HTTP timeout for upstream calls
HTTP_TIMEOUT=10
